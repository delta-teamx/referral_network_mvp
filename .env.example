# ============================================================================
# VirtualProsNetwork — Environment Variables
# Copy this file to .env and fill in values as needed.
# ============================================================================

# ---- App ---------------------------------------------------------------------
NODE_ENV=development
APP_NAME=VirtualProsNetwork
FRONTEND_URL=http://localhost:3000
API_URL=http://localhost:3001
PORT=3001

# ---- Database (PostgreSQL + PostGIS) -----------------------------------------
DATABASE_URL=postgresql://refnet:refnet_dev@localhost:5432/referral_network?schema=public
# Direct connection for Prisma migrations (bypasses connection pooler)
DIRECT_DATABASE_URL=postgresql://refnet:refnet_dev@localhost:5432/referral_network?schema=public

# ---- Redis (cache + BullMQ) --------------------------------------------------
REDIS_URL=redis://localhost:6379

# ---- Elasticsearch -----------------------------------------------------------
ELASTICSEARCH_URL=http://localhost:9200

# ---- JWT (Branch 2) ----------------------------------------------------------
JWT_ACCESS_SECRET=replace-me-min-32-chars-access-secret-goes-here
JWT_REFRESH_SECRET=replace-me-min-32-chars-refresh-secret-goes-here
JWT_ACCESS_TTL=1h
JWT_REFRESH_TTL=30d

# ---- OAuth (Branch 2) --------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/api/v1/auth/oauth/google/callback
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_CALLBACK_URL=http://localhost:3001/api/v1/auth/oauth/facebook/callback

# ---- Stripe (Branch 5) -------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=
STRIPE_PREMIUM_PRICE_ID=

# ---- AWS S3 (Branch 3 — listing photos) --------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=referral-network-uploads

# ---- Email (SES or SendGrid) (Branch 2) --------------------------------------
EMAIL_FROM=noreply@virtualprosnetwork.com
RESEND_API_KEY=
SENDGRID_API_KEY=

# ---- Google Maps --------------------------------------------------
GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# ---- Admin bootstrap (seed) --------------------------------------------------
# Comma-separated list of admin emails. These get ADMIN role on `prisma db seed`.
ADMIN_EMAILS=admin1@example.com,admin2@example.com,admin3@example.com
# Shared initial password — admins should change this on first login.
ADMIN_PASSWORD=ChangeMe_Strong123!

# ---- Frontend public env -----------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_APP_NAME=VirtualProsNetwork
