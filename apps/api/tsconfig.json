{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2022"],
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "types": ["node"],
    "outDir": "./dist",
    "declaration": false,
    "declarationMap": false,
    "baseUrl": ".",
    "paths": {
      "@refnet/shared": ["../../packages/shared/src/index.ts"],
      "@refnet/shared/*": ["../../packages/shared/src/*"]
    }
  },
  "include": ["src/**/*", "prisma/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
